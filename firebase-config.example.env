# Firebase Configuration for ReFut Landing
# Copy to .env.local for development

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=refut-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=refut-app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=refut-app.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# --- Entorno (Vercel: refut-landing @ landing.refut.app) ---
NEXT_PUBLIC_DEPLOY_ENV=staging
NEXT_PUBLIC_SITE_URL=https://landing.refut.app
NEXT_PUBLIC_APP_URL=https://dev.refut.app

# Protección de vista previa (server-only en Vercel; no usar NEXT_PUBLIC_)
STAGING_ACCESS_SECRET=genera-un-secreto-largo-aqui

# Opcional: bypass de Vercel Deployment Protection (mismo valor en ambos proyectos)
# VERCEL_AUTOMATION_BYPASS_SECRET=

# Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Admin panel (/admin) — cambiar en producción
NEXT_PUBLIC_ADMIN_PASSWORD=refut2024
